{
	"name": "pl_ingest_csv_full_batch_bronze",
	"properties": {
		"activities": [
			{
				"name": "set_run_id",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "v_run_id",
					"value": "@string(guid())"
				}
			},
			{
				"name": "gm_get_file_list",
				"type": "GetMetadata",
				"dependsOn": [
					{
						"activity": "set_run_id",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_adls_csv_ingest_source",
						"type": "DatasetReference",
						"parameters": {
							"p_source_container": {
								"value": "@pipeline().parameters.p_source_container",
								"type": "Expression"
							},
							"p_source_directory": {
								"value": "@pipeline().parameters.p_source_directory",
								"type": "Expression"
							},
							"p_file_name": "''"
						}
					},
					"fieldList": [
						"childItems"
					],
					"storeSettings": {
						"type": "AzureBlobFSReadSettings",
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			},
			{
				"name": "fe_process_files",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "gm_get_file_list",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('gm_get_file_list').output.childItems",
						"type": "Expression"
					},
					"batchCount": 2,
					"activities": [
						{
							"name": "set_current_file",
							"type": "SetVariable",
							"dependsOn": [],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "v_current_file",
								"value": {
									"value": "@item().name",
									"type": "Expression"
								}
							}
						},
						{
							"name": "gm_validate_file",
							"type": "GetMetadata",
							"dependsOn": [
								{
									"activity": "set_current_file",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataset": {
									"referenceName": "ds_adls_csv_ingest_source",
									"type": "DatasetReference",
									"parameters": {
										"p_source_container": {
											"value": "@pipeline().parameters.p_source_container",
											"type": "Expression"
										},
										"p_source_directory": {
											"value": "@pipeline().parameters.p_source_directory",
											"type": "Expression"
										},
										"p_file_name": {
											"value": "@variables('v_current_file')",
											"type": "Expression"
										}
									}
								},
								"fieldList": [
									"exists"
								],
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "DelimitedTextReadSettings"
								}
							}
						},
						{
							"name": "if_file_valid",
							"type": "IfCondition",
							"dependsOn": [
								{
									"activity": "gm_validate_file",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"expression": {
									"value": "@activity('gm_validate_file').output.exists",
									"type": "Expression"
								},
								"ifTrueActivities": [
									{
										"name": "cp_csv_to_parquet",
										"type": "Copy",
										"dependsOn": [],
										"policy": {
											"timeout": "0.12:00:00",
											"retry": 0,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"source": {
												"type": "DelimitedTextSource",
												"storeSettings": {
													"type": "AzureBlobFSReadSettings",
													"recursive": true,
													"enablePartitionDiscovery": false
												},
												"formatSettings": {
													"type": "DelimitedTextReadSettings"
												}
											},
											"sink": {
												"type": "ParquetSink",
												"storeSettings": {
													"type": "AzureBlobFSWriteSettings"
												},
												"formatSettings": {
													"type": "ParquetWriteSettings"
												}
											},
											"enableStaging": false,
											"translator": {
												"type": "TabularTranslator",
												"typeConversion": true,
												"typeConversionSettings": {
													"allowDataTruncation": true,
													"treatBooleanAsNumber": false
												}
											}
										},
										"inputs": [
											{
												"referenceName": "ds_adls_csv_ingest_source",
												"type": "DatasetReference",
												"parameters": {
													"p_source_container": {
														"value": "@pipeline().parameters.p_source_container",
														"type": "Expression"
													},
													"p_source_directory": {
														"value": "@pipeline().parameters.p_source_directory",
														"type": "Expression"
													},
													"p_file_name": {
														"value": "@variables('v_current_file')",
														"type": "Expression"
													}
												}
											}
										],
										"outputs": [
											{
												"referenceName": "ds_adls_parquet_ingest_bronze",
												"type": "DatasetReference",
												"parameters": {
													"p_target_container": {
														"value": "@pipeline().parameters.p_target_container",
														"type": "Expression"
													},
													"p_target_directory": {
														"value": "@pipeline().parameters.p_target_directory",
														"type": "Expression"
													},
													"p_file_name": {
														"value": "@replace(variables('v_current_file'), '.csv.txt', '.parquet')",
														"type": "Expression"
													}
												}
											}
										]
									}
								]
							}
						}
					]
				}
			}
		],
		"parameters": {
			"p_source_container": {
				"type": "string",
				"defaultValue": "raw"
			},
			"p_source_directory": {
				"type": "string",
				"defaultValue": "flat-files/customers"
			},
			"p_target_container": {
				"type": "string",
				"defaultValue": "bronze"
			},
			"p_target_directory": {
				"type": "string",
				"defaultValue": "flat-files/customers"
			},
			"p_file_extension": {
				"type": "string"
			},
			"p_parallelism": {
				"type": "string"
			}
		},
		"variables": {
			"v_run_id": {
				"type": "String"
			},
			"v_current_file": {
				"type": "String"
			}
		},
		"annotations": []
	}
}